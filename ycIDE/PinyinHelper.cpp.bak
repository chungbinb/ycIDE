std::wstring PinyinHelper::GetPinyin(wchar_t ch) {
    Initialize();
    
    // 1. 先查手动映射表
    auto it = pinyinMap.find(ch);
    if (it != pinyinMap.end()) {
        return it->second;
    }
    
    // 2. 查 IME 缓存
    auto itCache = imeCacheMap.find(ch);
    if (itCache != imeCacheMap.end()) {
        return itCache->second;
    }
    
    // 3. 如果是汉字（CJK统一汉字区），用 IME API 获取拼音
    if (ch >= 0x4E00 && ch <= 0x9FFF) {
        std::wstring py = GetPinyinByIME(ch);
        imeCacheMap[ch] = py;  // 缓存结果（即使为空也缓存，避免重复查询）
        return py;
    }
    
    return L"";
}

// 使用 Windows IME API 获取汉字拼音
std::wstring PinyinHelper::GetPinyinByIME(wchar_t ch) {
    HKL hKL = NULL;
    
    // 尝试获取微软拼音输入法
    int nLayouts = GetKeyboardLayoutList(0, NULL);
    if (nLayouts > 0) {
        std::vector<HKL> layouts(nLayouts);
        GetKeyboardLayoutList(nLayouts, layouts.data());
        for (HKL layout : layouts) {
            LANGID langId = LOWORD((DWORD_PTR)layout);
            // 查找中文输入法
            if (PRIMARYLANGID(langId) == LANG_CHINESE) {
                // 检查是否支持转换
                if (ImmIsIME(layout)) {
                    hKL = layout;
                    break;
                }
            }
        }
    }
    
    // 如果没找到中文输入法，尝试加载微软拼音
    if (!hKL) {
        hKL = LoadKeyboardLayoutW(L"00000804", KLF_NOTELLSHELL);
    }
    
    if (!hKL) return L"";
    
    HIMC hIMC = ImmCreateContext();
    if (!hIMC) return L"";
    
    wchar_t src[2] = { ch, 0 };
    
    // 获取转换结果所需的缓冲区大小
    DWORD dwSize = ImmGetConversionListW(hKL, hIMC, src, NULL, 0, GCL_REVERSECONVERSION);
    
    std::wstring result;
    if (dwSize > 0) {
        std::vector<BYTE> buffer(dwSize);
        CANDIDATELIST* pCandList = (CANDIDATELIST*)buffer.data();
        
        DWORD ret = ImmGetConversionListW(hKL, hIMC, src, pCandList, dwSize, GCL_REVERSECONVERSION);
        if (ret > 0 && pCandList->dwCount > 0) {
            // 获取第一个候选（拼音）
            wchar_t* pPinyin = (wchar_t*)((BYTE*)pCandList + pCandList->dwOffset[0]);
            result = pPinyin;
            
            // 转小写
            for (auto& c : result) {
                if (c >= L'A' && c <= L'Z') c += 32;
            }
            
            // 去掉声调数字（如果有的话）
            while (!result.empty() && result.back() >= L'0' && result.back() <= L'9') {
                result.pop_back();
            }
        }
    }
    
    ImmDestroyContext(hIMC);
    return result;
}

std::wstring PinyinHelper::GetStringPinyin(const std::wstring& str) {
    Initialize();
    std::wstring result;
    for (wchar_t ch : str) {
        std::wstring py = GetPinyin(ch);
        if (!py.empty()) {
            result += py;
        } else {
            result += ch;
        }
    }
    return result;
}

std::wstring PinyinHelper::GetStringInitials(const std::wstring& str) {
    Initialize();
    std::wstring result;
    for (wchar_t ch : str) {
        std::wstring py = GetPinyin(ch);
        if (!py.empty()) {
            result += py[0];
        } else {
            result += ch;
        }
    }
    return result;
}

std::vector<std::wstring> PinyinHelper::GetStringPinyins(const std::wstring& str) {
    Initialize();
    std::vector<std::wstring> results;
    results.push_back(L"");
    
    for (wchar_t ch : str) {
        std::vector<std::wstring> currentPinyins;
        
        // 检查多音字
        auto itMulti = multiPinyinMap.find(ch);
        if (itMulti != multiPinyinMap.end()) {
            currentPinyins = itMulti->second;
        } else {
            // 检查单音字
            auto it = pinyinMap.find(ch);
            if (it != pinyinMap.end()) {
                currentPinyins.push_back(it->second);
            } else {
                // 非汉字
                currentPinyins.push_back(std::wstring(1, ch));
            }
        }
        
        std::vector<std::wstring> newResults;
        for (const auto& prefix : results) {
            for (const auto& py : currentPinyins) {
                newResults.push_back(prefix + py);
            }
        }
        results = newResults;
    }
    return results;
}

std::vector<std::wstring> PinyinHelper::GetStringInitialsList(const std::wstring& str) {
    Initialize();
    std::vector<std::wstring> results;
    results.push_back(L"");
    
    for (wchar_t ch : str) {
        std::vector<std::wstring> currentInitials;
        
        // 检查多音字
        auto itMulti = multiPinyinMap.find(ch);
        if (itMulti != multiPinyinMap.end()) {
            for (const auto& py : itMulti->second) {
                if (!py.empty()) {
                    // 避免重复首字母
                    std::wstring initial = py.substr(0, 1);
                    bool exists = false;
                    for (const auto& existing : currentInitials) {
                        if (existing == initial) {
                            exists = true;
                            break;
                        }
                    }
                    if (!exists) {
                        currentInitials.push_back(initial);
                    }
                }
            }
        } else {
            // 检查单音字
            auto it = pinyinMap.find(ch);
            if (it != pinyinMap.end() && !it->second.empty()) {
                currentInitials.push_back(it->second.substr(0, 1));
            } else {
                // 非汉字
                currentInitials.push_back(std::wstring(1, ch));
            }
        }
        
        std::vector<std::wstring> newResults;
        for (const auto& prefix : results) {
            for (const auto& ini : currentInitials) {
                newResults.push_back(prefix + ini);
            }
        }
        results = newResults;
    }
    return results;
}
